{
  "manifest_version": 3,
  "name": "Fake Profile Detection",
  "version": "1.0",
  "description": "Detects fake profiles on Twitter/X using AI.",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": [
        "shared/featureEngineering.js",
        "shared/explain.js",
        "shared/risk.js",
        "platforms/twitter.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://smart-fake-profile-detection.onrender.com/*",
    "https://zoxmchlwfxnudopusksr.supabase.co/*",
    "https://twitter.com/*",
    "https://x.com/*"
  ]
}
