{
  "manifest_version": 3,
  "name": "Fake Profile Detection",
  "version": "1.0",
  "description": "Detects fake profiles on Twitter/X using AI.",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://twitter.com/*",
    "https://x.com/*"
  ]
}